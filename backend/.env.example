# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
API_PREFIX=/api

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ticketbro
MONGODB_URI_TEST=mongodb://localhost:27017/ticketbro_test

# ── JWT Secrets (REQUIRED — use long random strings, never commit real values) ─
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EMAIL_VERIFICATION_SECRET=REPLACE_WITH_EMAIL_VERIFICATION_SECRET
EMAIL_VERIFICATION_EXPIRES_IN=24h

PASSWORD_RESET_SECRET=REPLACE_WITH_PASSWORD_RESET_SECRET
PASSWORD_RESET_EXPIRES_IN=1h

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECRET=REPLACE_WITH_COOKIE_SECRET
COOKIE_SECURE=false          # set to true in production (forced true automatically)
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=Ticket Bro
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/facebook/callback

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Dev multiplier (×10) is applied automatically when NODE_ENV=development
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
